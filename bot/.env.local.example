# Lumenn Relay — Bot (Deno). Copie para .env.local e preencha. NUNCA commitar .env.local.
# App ID e Public Key: Discord Developer Portal -> General Information.
DISCORD_APP_ID=1515551691586670735
DISCORD_PUBLIC_KEY=
# Token do bot: Developer Portal -> Bot. ROTACIONAR antes do primeiro uso (ERR-004).
DISCORD_BOT_TOKEN=
# Supabase (service_role — nunca anon key no bot).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Chave interna para o endpoint /notify (API Rust -> Bot). Gerar aleatório seguro.
BOT_INTERNAL_KEY=
# ID do servidor de teste para registro instantâneo de comandos (opcional).
# Só usar para testes — deixar vazio para registro global.
DISCORD_GUILD_ID=
